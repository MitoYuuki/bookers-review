<%# ===== エラー表示 ===== %>
<% if @book.errors.any? %> 
  <%= @book.errors.count %>件のエラーが発生しました
  <ul>
    <% @book.errors.full_messages.each do |message| %>
      <li><%= message %></li>
    <% end %>
  </ul>
<% end %>

<%# ===== Books（見出し） ===== %>
<h1>Books</h1>

<%# ===== Title / Body（説明） ===== %>
<p>Title / Body</p>

<%# ===== 既存の Book 一覧 ===== %>
<div class="book-wrap">
  <% @books.each do |book| %>
    <div class="book-box">
      <div class="book-comment">
        <span class="book-body"><%= book.body %></span>
        <span class="book-title"><%= link_to book.title, book_path(book.id) %></span>
      </div>
    </div>
  <% end %>
</div>

<%# ===== New Book（新規投稿セクション） ===== %>
<h2>New Book</h2>

<%= form_with model: @book, url: '/books', method: :post do |f| %>

  <%# ===== Title / Body の投稿フォーム ===== %>
  <h4>Title</h4>
  <%= f.text_field :title %>

  <h4>Body</h4>
  <%= f.text_area :body %>

  <%# ===== Create Book ボタン ===== %>
  <%= f.submit 'Create Book' %>

<% end %>