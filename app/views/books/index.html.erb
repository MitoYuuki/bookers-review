<%# ===== エラー表示 ===== %>
<% if @book.errors.any? %> 
  <%= @book.errors.count %>件のエラーが発生しました
  <ul>
    <% @book.errors.full_messages.each do |message| %>
      <li><%= message %></li>
    <% end %>
  </ul>
<% end %>

<%# ===== Books（見出し） ===== %>
<h1>Books</h1>

<%# ===== 既存の Book 一覧（テーブル表示） ===== %>
<table class="books-table">
  <thead>
    <tr>
      <th>Title</th>
      <th>Body</th>
      <th></th>
    </tr>
  </thead>

  <tbody>
    <% @books.each do |book| %>
      <tr>
        <td><%= book.title %></td>
        <td><%= book.body %></td>
        <td>
          <%= link_to "Show", book_path(book.id) %>
          <%= link_to "Edit", edit_book_path(book.id) %>
          <%= link_to "Destroy", book_path(book.id),
                data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<%# ===== New Book（新規投稿セクション） ===== %>
<h2>New Book</h2>

<%= form_with model: @book, url: '/books', method: :post do |f| %>

  <%# ===== Title / Body の投稿フォーム ===== %>
  <h4>Title</h4>
  <%= f.text_field :title %>

  <h4>Body</h4>
  <%= f.text_area :body %>

  <%# ===== Create Book ボタン ===== %>
  <%= f.submit 'Create Book' %>

<% end %>